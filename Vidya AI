    gr.Markdown("## 📊 Resume Insights Dashboard")

    with gr.Row():
        skills_box = gr.Textbox(label="✅ Skills")
        missing_box = gr.Textbox(label="❌ Missing Skills")

    score_slider = gr.Slider(0, 100, label="📊 Score")

    with gr.Row():
        suggestion_box = gr.Textbox(label="💡 Suggestions")
        role_box = gr.Textbox(label="🎯 Roles")

    gr.Markdown("## 📚 Learning & Career Roadmap")

    with gr.Row():
        course_box = gr.Textbox(label="📚 Courses", lines=6)
        roadmap_box = gr.Textbox(label="🗺️ Roadmap", lines=6)
    gr.Markdown("## 🎤 AI Mock Interview")

    with gr.Row():
        role_input = gr.Textbox(label="Enter Job Role")
        gen_btn = gr.Button("Generate Questions")

    question_box = gr.Textbox(label="Interview Questions", lines=6)

    gen_btn.click(generate_questions, inputs=role_input, outputs=question_box)

    with gr.Row():
        answer_input = gr.Textbox(label="Your Answer", lines=4)
        eval_btn = gr.Button("Evaluate Answer")

    feedback_box = gr.Textbox(label="AI Feedback", lines=6)
    score_box = gr.Slider(0, 10, label="Interview Score")

    eval_btn.click(
    evaluate_answer,
    inputs=[role_input, answer_input],
    outputs=[score_box, feedback_box])
    
    analyze_btn.click(
        analyze_resume,
        inputs=file_input,
        outputs=[
            skills_box,
            missing_box,
            score_slider,
            suggestion_box,
            role_box,
            course_box,
            roadmap_box
        ]
    )

